# Hermes Agent on Render: environment variables
#
# This Blueprint deliberately keeps the env-var surface tiny. Only the
# vars listed below are managed by `render.yaml`. Provider keys, tool
# keys, and chat platform tokens are set through the Hermes dashboard
# (API Keys tab), which writes them to /opt/data/.env on the persistent
# disk. That file is the single source of truth, survives redeploys,
# and is the same UX as a local Hermes install.
#
# Full upstream env-var reference:
# https://github.com/NousResearch/hermes-agent/blob/main/.env.example

# =============================================================================
# Container boot config (set by the Blueprint, no user action needed)
# =============================================================================

# Enables the dashboard side-process inside the gateway container.
HERMES_DASHBOARD=1

# Bind the dashboard to all interfaces so Render's load balancer can reach it.
# The entrypoint passes --insecure automatically when this is non-loopback.
HERMES_DASHBOARD_HOST=0.0.0.0
HERMES_DASHBOARD_PORT=10000

# Exposes the in-browser Chat tab (full Hermes TUI through PTY + xterm.js).
# This is how you talk to the agent from the dashboard without a host TTY.
HERMES_DASHBOARD_TUI=1

# Generated by the Blueprint at first deploy (generateValue: true). Reuse
# this value as API_SERVER_KEY (in the dashboard) if you opt into the
# OpenAI-compatible API server.
HERMES_GATEWAY_TOKEN=

# Bearer token for the pre-registered Render MCP server. Get one at
# https://dashboard.render.com/u/*/settings#api-keys
#
# The MCP server's Authorization header is lazy-substituted from this
# var at gateway startup. Rotate from Render's Environment tab + restart;
# no rebuild needed.
#
# Named RENDER_MCP_API_KEY rather than the stock RENDER_API_KEY to avoid
# accidental auto-auth if someone later installs the `render` CLI. This
# is the same kind of Render API key; the Render account role behind the
# key determines what the agent can do.
RENDER_MCP_API_KEY=

# =============================================================================
# Everything else
# =============================================================================
# Set these from the Hermes dashboard (https://<your-service>.onrender.com),
# under the API Keys tab. Each entry shows a redacted preview, a description,
# and a link to the provider's signup page. Examples of what's available:
#
#   LLM providers (set at least one):
#     OPENROUTER_API_KEY, ANTHROPIC_API_KEY, OPENAI_API_KEY, GOOGLE_API_KEY,
#     HF_TOKEN, GLM_API_KEY, KIMI_API_KEY, OLLAMA_API_KEY, ...
#
#   Messaging platforms:
#     TELEGRAM_BOT_TOKEN, DISCORD_BOT_TOKEN, SLACK_BOT_TOKEN + SLACK_APP_TOKEN,
#     WHATSAPP_*, EMAIL_*, SIGNAL_*, TEAMS_*, GOOGLE_CHAT_*, ...
#
#   Tool API keys:
#     BROWSERBASE_API_KEY, EXA_API_KEY, FIRECRAWL_API_KEY, TAVILY_API_KEY,
#     HONCHO_API_KEY, GITHUB_TOKEN, ...
#
#   OpenAI-compatible API server (off by default):
#     API_SERVER_ENABLED, API_SERVER_KEY, API_SERVER_HOST, API_SERVER_CORS_ORIGINS
#
# If you'd rather set them via the Render Dashboard's Environment tab,
# that works too: Render env vars override values from /opt/data/.env at
# process start. Either path is fine; pick one and stick with it.
